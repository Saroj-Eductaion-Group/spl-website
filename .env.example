# =============================================
# SPL - Saroj Premier League Website
# Copy this file to .env and fill in values
# =============================================

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/spl?retryWrites=true&w=majority&ssl=true"

# Clerk Authentication (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-publishable-key"
CLERK_SECRET_KEY="sk_test_your-secret-key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/register"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/register"

# Email (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# SMS - Fast2SMS (https://www.fast2sms.com - free Indian SMS API)
FAST2SMS_API_KEY="your-fast2sms-api-key"

# Payment Gateway - Easebuzz
EASEBUZZ_KEY="your-easebuzz-key"
EASEBUZZ_SALT="your-easebuzz-salt"
EASEBUZZ_ENV="test"   # 'test' or 'prod'

# Cloudinary (document & image uploads — https://cloudinary.com)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# JWT Secret (for admin & coordinator tokens)
JWT_SECRET="your-strong-random-secret-min-32-chars"

# Public base URL (for payment callbacks)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
