# =============================================
# SPL - Saroj Premier League Website
# Copy this file to .env and fill in values
# =============================================

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/spl?retryWrites=true&w=majority&ssl=true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# Email (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# SMS - Fast2SMS (https://www.fast2sms.com - free Indian SMS API)
FAST2SMS_API_KEY="your-fast2sms-api-key"

# Payment Gateway (add when ready)
# RAZORPAY_KEY_ID="your-razorpay-key-id"
# RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
